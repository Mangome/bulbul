{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bulbul",
  "version": "0.5.3",
  "identifier": "com.bulbul.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1620",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "welcome",
        "title": "Bulbul",
        "width": 600,
        "height": 450,
        "resizable": false,
        "center": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; img-src 'self' data: asset: https://asset.localhost blob:; worker-src 'self' blob:; connect-src 'self' data: ipc: http://ipc.localhost http://asset.localhost asset: https://asset.localhost; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPLOCALDATA/**",
            "$APPCACHE/**",
            "$CACHE/**",
            "$HOME/**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2025 Bulbul",
    "shortDescription": "RAW 图像智能筛选与管理工具",
    "longDescription": "Bulbul 是一款桌面端 RAW 图像筛选与管理工具，支持 NEF 格式的智能分组、画布浏览和批量导出。",
    "category": "Photography",
    "resources": [
      "resources/models"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": [
          "SimpChinese",
          "English"
        ],
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      }
    }
  }
}
